# .env.docker — Copy this to .env on your VPS and fill in the values.
# cp .env.docker .env

# ── App security ───────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# ── Domain (used by Traefik labels in docker-compose.yml) ─────────────────
DOMAIN=chat.yourdomain.com

# ── Flask ──────────────────────────────────────────────────────────────────
FLASK_DEBUG=false
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ── Tesseract OCR ──────────────────────────────────────────────────────────
TESSERACT_CMD=/usr/bin/tesseract

# ── Ollama (optional — only if you run Ollama as a sidecar) ───────────────
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_LLM_MODEL=llama3
# OLLAMA_EMBED_MODEL=nomic-embed-text

# ── AI provider keys (set the ones you use) ────────────────────────────────
# GROQ_API_KEY=gsk_...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
# COHERE_API_KEY=...
