# ── Copy to .env on the Hostinger server ─────────────────────────────────
# SSH: cp .env.hostinger .env

# Flask (Passenger ignores HOST/PORT but Flask still reads DEBUG)
FLASK_DEBUG=false
FLASK_HOST=0.0.0.0
FLASK_PORT=7860

# ── AI Providers — set at least ONE ──────────────────────────────────────
# Pick any cloud provider; Ollama is NOT available on shared hosting.

# Groq (free tier, fast)  →  https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini            →  https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenRouter (many models) →  https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Mistral                  →  https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# Cohere                   →  https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# ── Tesseract OCR ─────────────────────────────────────────────────────────
# Not available on shared hosting — image OCR is disabled automatically.
# On a VPS: apt install tesseract-ocr && set path below.
# TESSERACT_CMD=/usr/bin/tesseract

# ── Ollama (local only) ───────────────────────────────────────────────────
# Not available on Hostinger shared hosting.
# OLLAMA_BASE_URL=http://localhost:11434

# ── Text chunking ─────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K_CHUNKS=4

# ── Suppress warnings ─────────────────────────────────────────────────────
HF_HUB_DISABLE_SYMLINKS_WARNING=1
TOKENIZERS_PARALLELISM=false
